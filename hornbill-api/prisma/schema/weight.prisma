model WeightEntry {
    id         String     @id @default(uuid())
    userId     String     @map("user_id")
    weight     Float
    unit       WeightUnit @default(KG) @map("unit")
    measuredAt DateTime   @default(now()) @map("measured_at")
    note       String?
    createdAt  DateTime   @default(now()) @map("created_at")
    updatedAt  DateTime   @updatedAt() @map("updated_at")
    user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("weight_entries")
}

model WeightGoal {
    id              String              @id @default(uuid())
    userId          String              @map("user_id")
    targetWeight    Float               @map("target_weight")
    unit            WeightUnit          @default(KG) @map("unit")
    direction       WeightGoalDirection
    mode            WeightGoalMode
    status          WeightGoalStatus    @default(IN_PROGRESS) @map("status")
    deadline        DateTime?           @map("deadline")
    toleranceWeight Float?              @map("tolerance_weight")
    note            String?
    resolvedAt      DateTime?           @map("resolved_at")
    createdAt       DateTime            @default(now()) @map("created_at")
    updatedAt       DateTime            @updatedAt() @map("updated_at")
    user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("weight_goals")
}

enum WeightUnit {
    KG
    LBS
}

enum WeightGoalDirection {
    GAIN
    LOSE
    MAINTAIN
}

enum WeightGoalMode {
    MILESTONE
    DEADLINE
}

enum WeightGoalStatus {
    FAILED
    SUCCESS
    IN_PROGRESS
}
