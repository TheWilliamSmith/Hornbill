generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(uuid())
  username      String        @unique
  firstName     String        @map("first_name")
  lastName      String        @map("last_name")
  email         String        @unique
  password      String
  role          UserRole      @default(USER)
  isVerified    Boolean       @default(false) @map("is_verified")
  lastLogin     DateTime?     @map("last_login")
  deletedAt     DateTime?     @map("deleted_at")
  sessions      Session[]
  weightEntries WeightEntry[]
  weightGoals   WeightGoal[]
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  USER
  ADMIN
}

model WeightEntry {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  weight     Float
  unit       WeightUnit @default(KG) @map("unit")
  measuredAt DateTime   @default(now()) @map("measured_at")
  note       String?
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt() @map("updated_at")
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("weight_entries")
}

model WeightGoal {
  id              String              @id @default(uuid())
  userId          String              @map("user_id")
  targetWeight    Float               @map("target_weight")
  unit            WeightUnit          @default(KG) @map("unit")
  direction       WeightGoalDirection
  mode            WeightGoalMode
  status          WeightGoalStatus    @default(IN_PROGRESS) @map("status")
  deadline        DateTime?           @map("deadline")
  toleranceWeight Float?              @map("tolerance_weight")
  note            String?
  resolvedAt      DateTime?           @map("resolved_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt() @map("updated_at")
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("weight_goals")
}

enum WeightUnit {
  KG
  LBS
}

enum WeightGoalDirection {
  GAIN
  LOSE
  MAINTAIN
}

enum WeightGoalMode {
  MILESTONE
  DEADLINE
}

enum WeightGoalStatus {
  FAILED
  SUCCESS
  IN_PROGRESS
}
