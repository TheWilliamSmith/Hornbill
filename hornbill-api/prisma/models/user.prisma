model User {
    id            String        @id @default(uuid())
    username      String        @unique
    firstName     String        @map("first_name")
    lastName      String        @map("last_name")
    email         String        @unique
    password      String
    role          UserRole      @default(USER)
    isVerified    Boolean       @default(false) @map("is_verified")
    isActive      Boolean       @default(true) @map("is_active")
    lastLogin     DateTime?     @map("last_login")
    deletedAt     DateTime?     @map("deleted_at")
    deactivatedAt DateTime?     @map("deactivated_at")
    deactivatedBy String?       @map("deactivated_by")
    sessions        Session[]
    weightEntries   WeightEntry[]
    weightGoals     WeightGoal[]
    cryptoPositions CryptoPosition[]
    notifications   Notification[]
    taskWorkspaces  TaskWorkspace[]
    habits          Habit[]
    discordWebhookUrl String?        @map("discord_webhook_url")
    deactivatedByUser User?          @relation("UserDeactivations", fields: [deactivatedBy], references: [id])
    deactivatedUsers  User[]         @relation("UserDeactivations")
    createdAt       DateTime         @default(now()) @map("created_at")
    updatedAt     DateTime      @updatedAt @map("updated_at")

    @@map("users")
}

enum UserRole {
    USER
    ADMIN
}
