meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: inherit
}

body:json {
  {
    "email": "MyEmails@gmail.com",
    "password": "MyPassword123!"
  }
}

script:post-response {
  bru.setEnvVar("accessToken", res.body.accessToken, "dev");
}

settings {
  encodeUrl: true
  timeout: 0
}
